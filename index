<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NRL 2026 — Round 4 Tipping Card</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0a1628;
    --navy-mid: #112240;
    --navy-light: #1a3356;
    --gold: #f0b429;
    --gold-light: #f7c948;
    --gold-dim: #c8941f;
    --white: #ffffff;
    --off-white: #e8edf5;
    --grey: #8899aa;
    --grey-light: #b8c8d8;
    --banker-bg: #0d3320;
    --banker-text: #3ddc84;
    --banker-border: #1a5c38;
    --strong-bg: #1a2e0a;
    --strong-text: #7ecf3a;
    --strong-border: #2d5012;
    --coinflip-bg: #2a1f00;
    --coinflip-text: #f0b429;
    --coinflip-border: #5a4000;
    --review-bg: #2a0a00;
    --review-text: #ff6b35;
    --review-border: #5a1800;
    --lower-bg: #1e1a00;
    --lower-text: #d4a017;
    --lower-border: #4a3800;
    --done-bg: #0a1a2a;
    --done-text: #4a9eff;
    --done-border: #1a3a5a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #060e1a; font-family: 'Barlow', sans-serif; color: var(--white); min-height: 100vh; padding: 20px; }
  .card { width: 900px; margin: 0 auto; background: var(--navy); border: 1px solid var(--navy-light); border-radius: 4px; overflow: hidden; }
  .header { background: linear-gradient(135deg, #0a1628 0%, #1a3356 50%, #0a1628 100%); border-bottom: 3px solid var(--gold); padding: 28px 32px 24px; position: relative; overflow: hidden; }
  .header::before { content: ''; position: absolute; top: -40px; right: -40px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(240,180,41,0.08) 0%, transparent 70%); border-radius: 50%; }
  .header-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .header-title { font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 3px; color: var(--gold); text-transform: uppercase; margin-bottom: 6px; }
  .header-round { font-family: 'Barlow Condensed', sans-serif; font-size: 52px; font-weight: 900; line-height: 1; color: var(--white); letter-spacing: -1px; }
  .header-round span { color: var(--gold); }
  .header-subtitle { font-size: 13px; color: var(--grey-light); margin-top: 6px; font-weight: 500; }
  .header-record { text-align: right; }
  .record-label { font-size: 10px; letter-spacing: 2px; color: var(--grey); text-transform: uppercase; font-weight: 600; }
  .record-value { font-family: 'Barlow Condensed', sans-serif; font-size: 36px; font-weight: 800; color: var(--gold); line-height: 1.1; }
  .record-pct { font-size: 13px; color: var(--grey-light); font-weight: 500; }
  .section { border-top: 1px solid var(--navy-light); }
  .section-header { padding: 14px 32px 12px; background: var(--navy-mid); border-bottom: 1px solid var(--navy-light); display: flex; align-items: center; gap: 10px; }
  .section-label { font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 3px; color: var(--gold); text-transform: uppercase; }
  .section-line { flex: 1; height: 1px; background: linear-gradient(to right, var(--gold-dim), transparent); opacity: 0.3; }
  .summary-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .summary-table th { padding: 10px 16px; text-align: left; font-family: 'Barlow Condensed', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: var(--grey); text-transform: uppercase; background: var(--navy-mid); border-bottom: 1px solid var(--navy-light); }
  .summary-table th:first-child { padding-left: 32px; width: 36px; }
  .summary-table th:last-child { padding-right: 32px; text-align: center; }
  .summary-table td { padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle; }
  .summary-table td:first-child { padding-left: 32px; color: var(--grey); font-size: 12px; font-weight: 600; }
  .summary-table td:last-child { padding-right: 32px; text-align: center; }
  .summary-table tr:last-child td { border-bottom: none; }
  .summary-table tr:hover td { background: rgba(255,255,255,0.02); }
  .game-name { font-weight: 600; color: var(--white); }
  .game-name .vs { color: var(--grey); font-weight: 400; margin: 0 4px; font-size: 12px; }
  .tip-team { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 15px; color: var(--gold); letter-spacing: 0.5px; }
  .pct { font-weight: 600; color: var(--white); }
  .pct-mkt { color: var(--grey-light); font-size: 12px; }
  .margin { font-weight: 600; }
  .margin.pos { color: #4a9eff; }
  .margin.neg { color: #ff7b7b; }
  .ou { color: var(--grey-light); font-size: 12px; }
  .table-note { padding: 8px 32px 12px; font-size: 11px; color: var(--grey); }
  .flag { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 3px; font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1px; white-space: nowrap; border: 1px solid; }
  .flag-banker { background: var(--banker-bg); color: var(--banker-text); border-color: var(--banker-border); }
  .flag-strong { background: var(--strong-bg); color: var(--strong-text); border-color: var(--strong-border); }
  .flag-coinflip { background: var(--coinflip-bg); color: var(--coinflip-text); border-color: var(--coinflip-border); }
  .flag-review { background: var(--review-bg); color: var(--review-text); border-color: var(--review-border); }
  .flag-lower { background: var(--lower-bg); color: var(--lower-text); border-color: var(--lower-border); }
  .flag-done { background: var(--done-bg); color: var(--done-text); border-color: var(--done-border); }
  .games-grid { padding: 0; }
  .game-card { border-bottom: 1px solid var(--navy-light); position: relative; }
  .game-card:last-child { border-bottom: none; }
  .game-card-inner { padding: 20px 32px; }
  .game-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
  .game-num { font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 700; color: var(--grey); letter-spacing: 2px; margin-bottom: 2px; }
  .game-matchup { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; color: var(--white); line-height: 1.1; }
  .game-matchup .tipped { color: var(--gold); }
  .game-meta { font-size: 11px; color: var(--grey); margin-top: 4px; display: flex; gap: 12px; align-items: center; }
  .game-meta span { display: flex; align-items: center; gap: 4px; }
  .weather-flag { color: #4ab4ff; }
  .game-tip-bar { background: var(--navy-mid); border: 1px solid var(--navy-light); border-radius: 3px; padding: 10px 16px; margin-bottom: 12px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .tip-label { font-family: 'Barlow Condensed', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: var(--grey); text-transform: uppercase; flex-shrink: 0; }
  .tip-team-lg { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 900; color: var(--gold); letter-spacing: 0.5px; }
  .tip-divider { color: var(--navy-light); font-size: 18px; }
  .tip-stat { display: flex; flex-direction: column; align-items: center; }
  .tip-stat-label { font-size: 9px; font-weight: 700; letter-spacing: 1.5px; color: var(--grey); text-transform: uppercase; }
  .tip-stat-value { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 700; color: var(--white); }
  .tip-stat-value.gold { color: var(--gold); }
  .tip-stat-value.green { color: #3ddc84; }
  .tip-stat-value.edge-nil { color: var(--grey); }
  .ml-auto { margin-left: auto; }
  .game-reasoning { font-size: 13px; line-height: 1.6; color: var(--off-white); margin-bottom: 10px; }
  .game-reasoning strong { color: var(--white); }
  .override-note { font-size: 12px; color: var(--grey-light); font-style: italic; padding: 8px 12px; border-left: 2px solid var(--gold-dim); margin-bottom: 10px; background: rgba(240,180,41,0.04); }
  .risk-note { font-size: 12px; color: var(--grey); display: flex; gap: 6px; align-items: flex-start; }
  .risk-note::before { content: '⚠'; color: var(--gold-dim); flex-shrink: 0; margin-top: 1px; }
  .review-block { background: rgba(255,107,53,0.04); border: 1px solid var(--review-border); border-radius: 3px; padding: 14px 16px; margin-bottom: 12px; }
  .review-header { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; color: var(--review-text); text-transform: uppercase; margin-bottom: 10px; }
  .review-row { display: flex; gap: 8px; margin-bottom: 6px; font-size: 13px; line-height: 1.5; }
  .review-row:last-child { margin-bottom: 0; }
  .review-arrow { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; color: var(--review-text); flex-shrink: 0; width: 60px; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; padding-top: 2px; }
  .review-arrow.verdict { color: var(--gold); }
  .review-text { color: var(--off-white); }
  .summary-grid { padding: 20px 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .summary-item { display: flex; gap: 12px; align-items: flex-start; padding: 12px 14px; background: var(--navy-mid); border: 1px solid var(--navy-light); border-radius: 3px; }
  .summary-item.full-width { grid-column: 1 / -1; }
  .summary-icon { font-size: 18px; flex-shrink: 0; line-height: 1.3; }
  .summary-type { font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 2px; color: var(--grey); text-transform: uppercase; margin-bottom: 3px; }
  .summary-detail { font-size: 13px; color: var(--off-white); line-height: 1.5; }
  .summary-detail strong { color: var(--gold); }
  .group-chat-block { padding: 24px 32px; background: linear-gradient(180deg, var(--navy-mid) 0%, var(--navy) 100%); }
  .group-chat-label { display: inline-flex; align-items: center; gap: 8px; background: var(--gold); color: var(--navy); padding: 5px 14px; font-family: 'Barlow Condensed', sans-serif; font-size: 11px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; border-radius: 2px; margin-bottom: 16px; }
  .group-chat-text { font-size: 14px; line-height: 1.7; color: var(--off-white); }
  .group-chat-text p { margin-bottom: 10px; }
  .group-chat-text p:last-child { margin-bottom: 0; }
  .group-chat-text strong { color: var(--white); }
  .full-card-line { color: var(--gold); font-weight: 600; }
  .footer { padding: 14px 32px; border-top: 1px solid var(--navy-light); background: var(--navy-mid); display: flex; justify-content: space-between; align-items: center; }
  .footer-left { font-size: 11px; color: var(--grey); letter-spacing: 1px; }
  .footer-right { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; color: var(--grey); letter-spacing: 1px; }
  .footer-right span { color: var(--gold); }
</style>
</head>
<body>
<div class="card">
 
  <!-- HEADER -->
  <div class="header">
    <div class="header-top">
      <div>
        <div class="header-title">NRL 2026 Tipping Card</div>
        <div class="header-round">ROUND <span>4</span></div>
        <div class="header-subtitle">26–29 March 2026</div>
      </div>
      <div class="header-record">
        <div class="record-label">Season Record</div>
        <div class="record-value">18/24</div>
        <div class="record-pct">75.0% accuracy</div>
      </div>
    </div>
  </div>
 
  <!-- SUMMARY TABLE -->
  <div class="section">
    <div class="section-header">
      <span class="section-label">Summary</span>
      <div class="section-line"></div>
    </div>
    <table class="summary-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Game</th>
          <th>Tip</th>
          <th>Model%</th>
          <th>Mkt%</th>
          <th>Margin</th>
          <th>O/U</th>
          <th>Flag</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>G1</td>
          <td><span class="game-name">Sea Eagles <span class="vs">v</span> Roosters</span></td>
          <td><span class="tip-team">ROOSTERS</span></td>
          <td><span class="pct">51%→59%*</span></td>
          <td><span class="pct-mkt">59%</span></td>
          <td><span class="margin neg">−6</span></td>
          <td><span class="ou">38</span></td>
          <td><span class="flag flag-lower">⬇️ LOWER CONF</span></td>
        </tr>
        <tr>
          <td>G2</td>
          <td><span class="game-name">Warriors <span class="vs">v</span> Tigers</span></td>
          <td><span class="tip-team">WARRIORS</span></td>
          <td><span class="pct">68%→80%*</span></td>
          <td><span class="pct-mkt">80%</span></td>
          <td><span class="margin pos">+24</span></td>
          <td><span class="ou">54</span></td>
          <td><span class="flag flag-banker">🔒 BANKER</span></td>
        </tr>
        <tr>
          <td>G3</td>
          <td><span class="game-name">Broncos <span class="vs">v</span> Dolphins</span></td>
          <td><span class="tip-team">BRONCOS</span></td>
          <td><span class="pct">58%</span></td>
          <td><span class="pct-mkt">61%</span></td>
          <td><span class="margin pos">+16</span></td>
          <td><span class="ou">46 ★</span></td>
          <td><span class="flag flag-strong">💪 STRONG</span></td>
        </tr>
        <tr>
          <td>G4</td>
          <td><span class="game-name">Bulldogs <span class="vs">v</span> Knights</span></td>
          <td><span class="tip-team">BULLDOGS</span></td>
          <td><span class="pct">57%</span></td>
          <td><span class="pct-mkt">67%</span></td>
          <td><span class="margin pos">+18</span></td>
          <td><span class="ou">46</span></td>
          <td></td>
        </tr>
        <tr>
          <td>G5</td>
          <td><span class="game-name">Panthers <span class="vs">v</span> Eels</span></td>
          <td><span class="tip-team">PANTHERS</span></td>
          <td><span class="pct">63%→74%*</span></td>
          <td><span class="pct-mkt">74%</span></td>
          <td><span class="margin pos">+22</span></td>
          <td><span class="ou">48</span></td>
          <td><span class="flag flag-strong">💪 STRONG</span></td>
        </tr>
        <tr>
          <td>G6</td>
          <td><span class="game-name">Cowboys <span class="vs">v</span> Storm</span></td>
          <td><span class="tip-team">STORM</span></td>
          <td><span class="pct">52%</span></td>
          <td><span class="pct-mkt">57%</span></td>
          <td><span class="margin neg">−2</span></td>
          <td><span class="ou">43</span></td>
          <td><span class="flag flag-coinflip">🪙 COIN-FLIP</span></td>
        </tr>
        <tr>
          <td>G7</td>
          <td><span class="game-name">Raiders <span class="vs">v</span> Sharks</span></td>
          <td><span class="tip-team">RAIDERS</span></td>
          <td><span class="pct">49%→54%*</span></td>
          <td><span class="pct-mkt">54%</span></td>
          <td><span class="margin pos">+6</span></td>
          <td><span class="ou">40</span></td>
          <td><span class="flag flag-lower">⬇️ LOWER CONF</span></td>
        </tr>
        <tr>
          <td>G8</td>
          <td><span class="game-name">Titans <span class="vs">v</span> Dragons</span></td>
          <td><span class="tip-team">TITANS</span></td>
          <td><span class="pct">56%</span></td>
          <td><span class="pct-mkt">61%</span></td>
          <td><span class="margin pos">+14</span></td>
